{
  "schemaVersion": "1.0",
  "deployment": {
    "name": "Customer Support Chatbot",
    "agency": "Acme Corp (generic startup)",
    "description": "Public-facing customer-support chatbot answering product questions and handling first-tier support tickets. Authenticated logged-in users get richer answers; anonymous visitors get general FAQ-level support.",
    "publicFacing": true,
    "fedrampTier": "none"
  },
  "anchor_query": {
    "input_tokens": 8000,
    "output_tokens": 400,
    "cache_rate_baseline": 0.65,
    "session_baseline_turns": 5,
    "example": "Why was I charged twice on my last invoice and how can I get a refund?"
  },
  "shapes": {
    "faq":      { "input_factor": 0.30, "output_factor": 0.60, "cache_eligible": true,  "description": "FAQ lookup; common topics" },
    "support":  { "input_factor": 1.00, "output_factor": 1.00, "cache_eligible": true,  "description": "Multi-turn support interaction (anchor)" },
    "escalate": { "input_factor": 0.40, "output_factor": 0.30, "cache_eligible": true,  "description": "Hand-off to a human agent" },
    "refusal":  { "input_factor": 0.05, "output_factor": 0.10, "cache_eligible": false, "description": "Out-of-scope refusal" }
  },
  "mix": {
    "default": { "label": "Default support mix (60/25/10/5)", "weights": { "faq": 0.60, "support": 0.25, "escalate": 0.10, "refusal": 0.05 } }
  },
  "segments": [
    { "id": "users",     "label": "Logged-in customers",   "mau":  50000, "sessions_per_day": 0.05, "questions_per_session": 4, "applyBotFactor": false },
    { "id": "anonymous", "label": "Anonymous web visitors", "mau": 250000, "sessions_per_day": 0.02, "questions_per_session": 2, "applyBotFactor": true }
  ],
  "verification": { "enabled": false, "coverage": 0, "atoms_per_response": 6, "variant": "fr1", "atomizer_tokens": { "input": 1200, "output": 350 }, "reviser_tokens": { "input": 500, "output": 30 }, "nli_tokens": { "input": 1000, "output": 20 }, "retrieval": "wikipedia", "nli_hosting": "api", "service_pod_monthly": 0 },
  "rate_limit":   { "strategy": "edge", "monthly_cost": 15, "bot_ceiling": 2.5 },
  "daily_cap":    { "enabled": true, "amount_usd": 800, "burst_days": 4, "burst_factor": 2.0 },
  "infrastructure": { "Compute platform": 179, "RDS Postgres": 150, "ALB": 35, "CloudFront": 40, "CloudWatch + X-Ray": 100 },
  "defaults": { "model": "gpt-5-mini", "tier": "standard", "mix": "default", "rate_limit": "edge", "hosting": "api", "cost_mode": "realistic" }
}
