# Secrets — never commit
.env
.env.local

# Trace JSONs (reports/*-trace.json) are the measured evidence the paper
# cites for every calibrated coefficient, so they ARE committed -- a
# reviewer must be able to check the numbers without re-spending on
# provider APIs. Validation reports (*-validation.md) are likewise kept.
# Variance dumps stay out: re-runnable scratch, not cited.
reports/*-variance.md
reports/*-variance.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# IDE
.vscode/
.idea/
reports/*.log
