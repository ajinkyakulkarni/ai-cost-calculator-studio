# agent-cost-bench — environment template.
# Copy to .env and fill in your keys:  cp .env.example .env
# .env is gitignored. Never commit real keys.

# Provider API keys. You only need the key(s) for the provider(s) your
# scenarios target — most scenarios use OpenAI; the Anthropic cache
# scenarios need the Anthropic key.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: set to 1 to also print OTEL GenAI spans to the console as
# scenarios run (handy when debugging a new scenario). Leave blank/0 off.
AGENT_COST_BENCH_CONSOLE_TRACES=
